-- ==================== TELEPORT FUNCTIONS ====================
local function getCharacter()
    return player.Character or player.CharacterAdded:Wait()
end

local function isPlayerHead(head)
    local model = head.Parent
    if model and model:IsA("Model") then
        local humanoid = model:FindFirstChildOfClass("Humanoid")
        if humanoid then
            for _, plr in pairs(Players:GetPlayers()) do
                if plr.Character == model then return true end
            end
        end
    end
    return false
end

local function findTargetNPC(character)
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    local rootPart = character.HumanoidRootPart
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if not npcsFolder then return nil end

    local bestHead = nil

    if teleportHighestRarity then
        local highestRarity = -math.huge
        for _, npc in pairs(npcsFolder:GetChildren()) do
            if npc:IsA("Model") then
                local head = npc:FindFirstChild("Head")
                local humanoid = npc:FindFirstChildOfClass("Humanoid")
                if head and humanoid and humanoid.Health > 0 and not isPlayerHead(head) then
                    local distance = (rootPart.Position - head.Position).Magnitude
                    if distance <= TELEPORT_MAX_RANGE then
                        local rarityValue = npc:GetAttribute("Rarity")
                        if rarityValue and rarityValue > TELEPORT_MIN_RARITY and rarityValue > highestRarity then
                            highestRarity = rarityValue
                            bestHead = head
                        end
                    end
                end
            end
        end
    else
        local nearestDistance = TELEPORT_MAX_RANGE
        for _, npc in pairs(npcsFolder:GetChildren()) do
            if npc:IsA("Model") then
                local head = npc:FindFirstChild("Head")
                local humanoid = npc:FindFirstChildOfClass("Humanoid")
                if head and humanoid and humanoid.Health > 0 and not isPlayerHead(head) then
                    local distance = (rootPart.Position - head.Position).Magnitude
                    local rarityValue = npc:GetAttribute("Rarity")
                    if distance < nearestDistance and rarityValue and rarityValue > TELEPORT_MIN_RARITY then
                        nearestDistance = distance
                        bestHead = head
                    end
                end
            end
        end
    end

    return bestHead
end

local function createBodyMovers(character)
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local rootPart = character.HumanoidRootPart
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(GYRO_TORQUE, GYRO_TORQUE, GYRO_TORQUE)
    bodyGyro.P = 10000
    bodyGyro.D = 500
    bodyGyro.Parent = rootPart
end

local function removeBodyMovers()
    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
end

function teleportLoop()
    local lastCheck = 0
    teleportConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not teleportEnabled then return end
        local character = player.Character
        if not character or not character:FindFirstChild("HumanoidRootPart") then return end
        local rootPart = character.HumanoidRootPart
        lastCheck = lastCheck + deltaTime
        if lastCheck >= CHECK_INTERVAL then
            lastCheck = 0
            currentTarget = findTargetNPC(character)
        end
        if currentTarget and currentTarget.Parent then
            local humanoid = currentTarget.Parent:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                if not bodyVelocity or not bodyVelocity.Parent then createBodyMovers(character) end
                local targetPosition = currentTarget.Position + Vector3.new(0, HOVER_HEIGHT, 0)
                local lookAtCFrame = CFrame.lookAt(targetPosition, currentTarget.Position)
                rootPart.CFrame = lookAtCFrame
                if bodyGyro and bodyGyro.Parent then
                    bodyGyro.CFrame = CFrame.lookAt(rootPart.Position, currentTarget.Position)
                end
            else currentTarget = nil end
        else
            removeBodyMovers()
            currentTarget = nil
        end
    end)
end

function stopTeleportLoop()
    if teleportConnection then teleportConnection:Disconnect() teleportConnection = nil end
    removeBodyMovers()
    currentTarget = nil
end

-- ==================== ESP FUNCTIONS ====================
local function createESP(npc)
    if espObjects[npc] then return end
    local head = npc:FindFirstChild("Head")
    if not head then return end
    local rarityValue = npc:GetAttribute("Rarity")
    if not rarityValue or rarityValue <= MIN_RARITY then return end
    local gui = head:FindFirstChild("Gui")
    if not gui then return end
    local main = gui:FindFirstChild("Main")
    if not main then return end
    local info = main:FindFirstChild("Info")
    if not info then return end
    local rarityLabel = info:FindFirstChild("Rarity")
    if not rarityLabel or not rarityLabel:IsA("TextLabel") then return end
    local rarityText = rarityLabel.Text
    local mobName = npc.Name
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP"
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, 96, 0, 24)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = head
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = string.format("%s | %s", mobName, rarityText)
    textLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
    textLabel.TextStrokeTransparency = 0.5
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.Jura
    textLabel.Parent = billboard
    espObjects[npc] = billboard
end

local function removeESP(npc)
    if espObjects[npc] then espObjects[npc]:Destroy() espObjects[npc] = nil end
end

local function shouldHaveESP(npc, playerChar)
    if not espEnabled then return false end
    if not npc or not npc:IsA("Model") then return false end
    if not playerChar or not playerChar:FindFirstChild("HumanoidRootPart") then return false end
    local head = npc:FindFirstChild("Head")
    local humanoid = npc:FindFirstChildOfClass("Humanoid")
    if not head or not humanoid or humanoid.Health <= 0 then return false end
    local rarityValue = npc:GetAttribute("Rarity")
    if not rarityValue or rarityValue <= MIN_RARITY then return false end
    local distance = (playerChar.HumanoidRootPart.Position - head.Position).Magnitude
    if distance > ESP_MAX_RANGE then return false end
    return true
end

local function espLoop()
    RunService.Heartbeat:Connect(function()
        local character = player.Character
        if not character then return end
        local npcsFolder = workspace:FindFirstChild("NPCs")
        if not npcsFolder then return end
        local checkedNPCs = {}
        for _, npc in pairs(npcsFolder:GetChildren()) do
            checkedNPCs[npc] = true
            if shouldHaveESP(npc, character) then createESP(npc) else removeESP(npc) end
        end
        for npc, _ in pairs(espObjects) do
            if not checkedNPCs[npc] or not npc.Parent then removeESP(npc) end
        end
    end)
end

-- ==================== SWORD DAMAGE ESP FUNCTIONS ====================
local function createSwordESP(targetPlayer)
    if swordESPObjects[targetPlayer] then return end
    local character = targetPlayer.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    local damageValue = nil
    for _, tool in pairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            local damage = tool:FindFirstChild("Damage")
            if damage and damage:IsA("NumberValue") then
                damageValue = damage.Value
                break
            end
        end
    end
    if not damageValue then return end
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "SwordDMGESP"
    billboard.Adornee = rootPart
    billboard.Size = UDim2.new(0, 120, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = rootPart
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = abbreviateNumber(damageValue) .. " DMG"
    textLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    textLabel.TextStrokeTransparency = 0.5
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.GothamBold
    textLabel.Parent = billboard
    swordESPObjects[targetPlayer] = billboard
end

local function removeSwordESP(targetPlayer)
    if swordESPObjects[targetPlayer] then swordESPObjects[targetPlayer]:Destroy() swordESPObjects[targetPlayer] = nil end
end

local function updateSwordESP()
    if not swordDMGEnabled then
        for plr, billboard in pairs(swordESPObjects) do removeSwordESP(plr) end
        return
    end
    local checkedPlayers = {}
    for _, targetPlayer in pairs(Players:GetPlayers()) do
        if targetPlayer ~= player then
            checkedPlayers[targetPlayer] = true
            local character = targetPlayer.Character
            if character and character:FindFirstChild("HumanoidRootPart") then
                local hasDamageTool = false
                local damageValue = nil
                for _, tool in pairs(character:GetChildren()) do
                    if tool:IsA("Tool") then
                        local damage = tool:FindFirstChild("Damage")
                        if damage and damage:IsA("NumberValue") then
                            hasDamageTool = true
                            damageValue = damage.Value
                            break
                        end
                    end
                end
                if hasDamageTool and damageValue then
                    if swordESPObjects[targetPlayer] and swordESPObjects[targetPlayer].Parent then
                        local textLabel = swordESPObjects[targetPlayer]:FindFirstChildOfClass("TextLabel")
                        if textLabel then textLabel.Text = abbreviateNumber(damageValue) .. " DMG" end
                    else createSwordESP(targetPlayer) end
                else removeSwordESP(targetPlayer) end
            else removeSwordESP(targetPlayer) end
        end
    end
    for plr, _ in pairs(swordESPObjects) do
        if not checkedPlayers[plr] or not plr.Parent then removeSwordESP(plr) end
    end
end

local function swordESPLoop()
    RunService.Heartbeat:Connect(function() updateSwordESP() end)
end

Players.PlayerAdded:Connect(function(targetPlayer)
    targetPlayer.CharacterAdded:Connect(function()
        if swordESPObjects[targetPlayer] then removeSwordESP(targetPlayer) end
    end)
end)

-- ==================== FORTUNE + ANCIENT + INSIGHT FUNCTIONS ====================
local function hasFortuneAndAncient(sword)
    local enchant1 = sword:GetAttribute("Enchant1")
    local enchant2 = sword:GetAttribute("Enchant2")
    local enchant3 = sword:GetAttribute("Enchant3")
    local enchants = {enchant1, enchant2, enchant3}

    local fortuneCount = 0
    local ancientCount = 0
    local insightCount = 0

    for _, enchant in ipairs(enchants) do
        if enchant == 0  then fortuneCount = fortuneCount + 1 end
        if enchant == 11 then ancientCount = ancientCount + 1 end
        if enchant == 13 then insightCount = insightCount + 1 end
    end

    return ancientCount >= 2
        or (ancientCount >= 1 and fortuneCount >= 2)
        or (ancientCount >= 1 and fortuneCount >= 1 and insightCount >= 1)
end

local function createFortuneAncientPart(sword)
    if fortuneAncientParts[sword] then return end
    local mainPart = sword:FindFirstChild("Main")
    if not mainPart then return end
    local cylinder = Instance.new("Part")
    cylinder.Name = "FortuneAncientMarker_" .. sword.Name
    cylinder.Shape = Enum.PartType.Cylinder
    cylinder.Size = Vector3.new(2048, 1.5, 1.5)
    cylinder.Material = Enum.Material.Neon
    cylinder.Color = Color3.fromRGB(117, 0, 0)
    cylinder.Transparency = 0.4
    cylinder.CanCollide = false
    cylinder.CanQuery = false
    cylinder.CanTouch = false
    cylinder.Anchored = true
    cylinder.Rotation = Vector3.new(0, 0, 90)
    cylinder.Parent = workspace
    fortuneAncientParts[sword] = cylinder
    if not trackedSwords[sword] then
        trackedSwords[sword] = true
        playNotificationSound()
        print("Fortune + Ancient (+ Insight) Sword Found: " .. sword.Name)
    end
    sword.AncestryChanged:Connect(function()
        if not sword:IsDescendantOf(workspace) then
            if fortuneAncientParts[sword] then fortuneAncientParts[sword]:Destroy() fortuneAncientParts[sword] = nil end
            trackedSwords[sword] = nil
        end
    end)
end

local function removeFortuneAncientPart(sword)
    if fortuneAncientParts[sword] then fortuneAncientParts[sword]:Destroy() fortuneAncientParts[sword] = nil end
end

local function updateFortuneAncientParts()
    if not fortuneAncientEnabled then
        for sword, part in pairs(fortuneAncientParts) do part:Destroy() end
        fortuneAncientParts = {}
        trackedSwords = {}
        return
    end
    local swordsFolder = workspace:FindFirstChild("Swords")
    if not swordsFolder then return end
    local checkedSwords = {}
    for _, sword in pairs(swordsFolder:GetChildren()) do
        if sword:IsA("Model") then
            checkedSwords[sword] = true
            if hasFortuneAndAncient(sword) then
                local mainPart = sword:FindFirstChild("Main")
                if mainPart then
                    if not fortuneAncientParts[sword] then createFortuneAncientPart(sword) end
                    if fortuneAncientParts[sword] then
                        fortuneAncientParts[sword].CFrame = mainPart.CFrame * CFrame.Angles(0, 0, math.rad(90))
                    end
                end
            else removeFortuneAncientPart(sword) end
        end
    end
    for sword, part in pairs(fortuneAncientParts) do
        if not checkedSwords[sword] or not sword.Parent then
            removeFortuneAncientPart(sword)
            trackedSwords[sword] = nil
        end
    end
end

local function fortuneAncientLoop()
    RunService.Heartbeat:Connect(function() updateFortuneAncientParts() end)
end

