-- ==================== NUMBER ABBREVIATION FUNCTION ====================
local function abbreviateNumber(num)
    local suffixes = {{1e18, "QN"}, {1e15, "QD"}, {1e12, "T"}, {1e9, "B"}, {1e6, "M"}, {1e3, "K"}}
    for _, data in ipairs(suffixes) do
        local threshold, suffix = data[1], data[2]
        if num >= threshold then return string.format("%.2f%s", num / threshold, suffix) end
    end
    return tostring(math.floor(num))
end

-- ==================== SOUND NOTIFICATION FUNCTION ====================
local function playNotificationSound()
    task.spawn(function()
        local sound = Instance.new("Sound")
        sound.SoundId = "rbxasset://sounds/electronicpingshort.wav"
        sound.Volume = 10
        sound.Parent = SoundService
        local startTime = tick()
        local duration = 5
        local interval = 0.25
        while tick() - startTime < duration do
            sound:Play()
            wait(interval)
        end
        sound:Destroy()
    end)
end

-- ==================== PLAYER DETECTION FUNCTION ====================
local function isPlayerNearby()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    local rootPart = character.HumanoidRootPart
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") then
                local distance = (rootPart.Position - otherChar.HumanoidRootPart.Position).Magnitude
                if distance <= PLAYER_DETECTION_RANGE then return true end
            end
        end
    end
    return false
end

