-- ==================== PLAYER DETECTION FUNCTION ====================
local function isPlayerNearby()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    local rootPart = character.HumanoidRootPart
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") then
                local distance = (rootPart.Position - otherChar.HumanoidRootPart.Position).Magnitude
                if distance <= PLAYER_DETECTION_RANGE then return true end
            end
        end
    end
    return false
end

-- ==================== GET CURRENT HEALTH ====================
local function getMyHealth()
    local character = player.Character
    if not character then return nil end
    local charName = character.Name
    local hpFolder = workspace:FindFirstChild(charName)
    if not hpFolder then return nil end
    local hp = hpFolder:FindFirstChild("HP")
    if not hp then return nil end
    local health = hp:FindFirstChild("Health")
    if not health then return nil end
    return health.Value
end

-- ==================== TRIPLE SPAWN CALCULATOR ====================
local Luck25 = ReplicatedStorage.Values.Spawns.Luck25
local Luck100 = ReplicatedStorage.Values.Spawns.Luck100
local Luck500 = ReplicatedStorage.Values.Spawns.Luck500

local function findTriple()
	for i = 0,1000000 do
		if (Luck25.Value - i) % 6 == 0
		and (Luck100.Value - i) % 16 == 0
		and (Luck500.Value - i) % 51 == 0 then
			return i
		end
	end
	return "?"
end

