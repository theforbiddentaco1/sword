-- ==================== PLAYER DETECTION FUNCTION ====================
local function isPlayerNearby()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    local rootPart = character.HumanoidRootPart
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") then
                local distance = (rootPart.Position - otherChar.HumanoidRootPart.Position).Magnitude
                if distance <= PLAYER_DETECTION_RANGE then return true end
            end
        end
    end
    return false
end

-- ==================== SPAWN TRACKER FUNCTIONS ====================
local function formatTime(seconds)
    local hours = math.floor(seconds / 3600)
    local minutes = math.floor((seconds % 3600) / 60)
    local secs = math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", hours, minutes, secs)
end

local function calculateNextEvents()
    local luck10 = spawnValues.Luck10.Value
    local luck50 = spawnValues.Luck50.Value
    local luck250 = spawnValues.Luck250.Value
    local luck5 = spawnValues.Luck5.Value
    
    local events = {}
    
    -- Calculate when each spawn hits 0
    for i = 0, 250 do
        local spawnsUntil = i
        local luck10Hit = (luck10 - spawnsUntil) % 5 == 0 and (luck10 - spawnsUntil) <= 0
        local luck50Hit = (luck50 - spawnsUntil) % 15 == 0 and (luck50 - spawnsUntil) <= 0
        local luck250Hit = (luck250 - spawnsUntil) % 50 == 0 and (luck250 - spawnsUntil) <= 0
        local luck5Hit = (luck5 - spawnsUntil) % 125 == 0 and (luck5 - spawnsUntil) <= 0
        
        local eventType = nil
        local count = 0
        if luck10Hit then count = count + 1 end
        if luck50Hit then count = count + 1 end
        if luck250Hit then count = count + 1 end
        if luck5Hit then count = count + 1 end
        
        if count == 4 then
            eventType = "QUAD"
        elseif count == 3 then
            if luck10Hit and luck50Hit and luck250Hit then
                eventType = "TRIPLE"
            elseif luck5Hit and luck50Hit and luck250Hit then
                eventType = "TRIPLE2"
            end
        end
        
        if eventType and spawnsUntil > 0 then
            table.insert(events, {
                spawns = spawnsUntil,
                type = eventType,
                time = spawnsUntil * SPAWN_INTERVAL
            })
            if #events >= 5 then break end
        end
    end
    
    return events
end

