-- ==================== NUMBER ABBREVIATION FUNCTION ====================
local function abbreviateNumber(num)
    local suffixes = {{1e18, "QN"}, {1e15, "QD"}, {1e12, "T"}, {1e9, "B"}, {1e6, "M"}, {1e3, "K"}}
    for _, data in ipairs(suffixes) do
        local threshold, suffix = data[1], data[2]
        if num >= threshold then return string.format("%.2f%s", num / threshold, suffix) end
    end
    return tostring(math.floor(num))
end

