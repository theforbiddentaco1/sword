                task.wait(0.05)
                clickCenter()
                task.wait(CYCLE_DELAY)
            end
        end
    end
end)

-- ==================== LOW HEALTH AUTO TELEPORT ====================
local function setupHealthMonitor(character)
    local humanoid = character:WaitForChild("Humanoid")
    wasAboveThreshold = true
    humanoid.HealthChanged:Connect(function(health)
        if not lowHealthTeleportEnabled then return end
        local healthPercent = health / humanoid.MaxHealth
        local playerNearby = isPlayerNearby()
        local threshold = playerNearby and LOW_HEALTH_THRESHOLD_WITH_PLAYERS or LOW_HEALTH_THRESHOLD_NO_PLAYERS
        if healthPercent <= threshold and wasAboveThreshold then
            wasAboveThreshold = false
            local lowHealthChar = player.Character
            if lowHealthChar and lowHealthChar:FindFirstChild("HumanoidRootPart") then
                local rootPart = lowHealthChar.HumanoidRootPart
                rootPart.CFrame = CFrame.new(rootPart.Position + Vector3.new(0, 1000, 0))
            end
            local success, err = pcall(function()
                local args = {"Teleport Area", 3}
                ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction"):InvokeServer(unpack(args))
            end)
            if success then
                local thresholdText = playerNearby and "50% (player nearby)" or "25% (no players)"
                print("Low Health Teleport: Activated at " .. math.floor(healthPercent * 100) .. "% health (" .. thresholdText .. ")")
            else warn("Low Health Teleport: Failed - " .. tostring(err)) end
        elseif healthPercent > threshold then wasAboveThreshold = true end
    end)
end

-- ==================== HIGH DAMAGE THREAT DETECTION ====================
local function getThreatPlayers(character)
    if not character or not character:FindFirstChild("HumanoidRootPart") then return {} end

    local myHealth = getMyHealth()
    if not myHealth then return {} end

    local myRoot = character.HumanoidRootPart
    local threats = {}

    for _, targetPlayer in pairs(Players:GetPlayers()) do
        if targetPlayer == player then continue end
        local theirChar = targetPlayer.Character
        if not theirChar or not theirChar:FindFirstChild("HumanoidRootPart") then continue end

        local dist = (myRoot.Position - theirChar.HumanoidRootPart.Position).Magnitude
        if dist > THREAT_DETECTION_RANGE then continue end

        for _, tool in pairs(theirChar:GetChildren()) do
            if tool:IsA("Tool") then
                local dmgVal = tool:FindFirstChild("Damage")
                if dmgVal and dmgVal:IsA("NumberValue") then
                    local critDamage = dmgVal.Value * CRIT_MULTIPLIER
                    local hitsToKill = math.ceil(myHealth / dmgVal.Value)
                    if critDamage >= myHealth or hitsToKill <= HITS_TO_KILL then
                        table.insert(threats, targetPlayer)
                        break
                    end
                end
            end
        end
    end
    return threats
end

local function escapeThreat()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local rootPart = character.HumanoidRootPart
    rootPart.CFrame = CFrame.new(rootPart.Position + Vector3.new(0, 1000, 0))
    local success, err = pcall(function()
        local args = {"Teleport Area", 3}
        ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction"):InvokeServer(unpack(args))
    end)
    if success then
        print("High Damage Threat Escape: Teleported to safe zone!")
    else
        warn("High Damage Threat Escape: Remote failed - " .. tostring(err))
    end
end

local function threatDetectionLoop()
    RunService.Heartbeat:Connect(function()
        if not threatDetectionEnabled then
            hasEscapedThreat = {}
            return
        end
        local character = player.Character
        if not character then return end
        local threats = getThreatPlayers(character)
        if #threats > 0 then
            local key = ""
            for _, t in ipairs(threats) do key = key .. t.UserId end
            if not hasEscapedThreat[key] then
                hasEscapedThreat[key] = true
                print("High Damage Threat Detected! Escaping...")
                escapeThreat()
            end
        else
            hasEscapedThreat = {}
        end
    end)
end

