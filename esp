local function createChams(npc)
    if chamObjects[npc] then return end
    local humanoid = npc:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    local highlight = Instance.new("Highlight")
    highlight.Name = "ChamsHighlight"
    highlight.Adornee = npc
    highlight.FillColor = Color3.fromRGB(39, 169, 245)
    highlight.OutlineColor = Color3.fromRGB(217, 157, 242)
    highlight.FillTransparency = 0.6
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = npc
    chamObjects[npc] = highlight
end

local function removeChams(npc)
    if chamObjects[npc] then chamObjects[npc]:Destroy() chamObjects[npc] = nil end
end

local function updateChams()
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local rootPart = character.HumanoidRootPart
    local npcsFolder = workspace:FindFirstChild("NPCs")
    if not npcsFolder then return end
    local closestNPC = nil
    local closestDistance = math.huge
    local checkedNPCs = {}
    for _, npc in pairs(npcsFolder:GetChildren()) do
        if npc:IsA("Model") then
            local humanoid = npc:FindFirstChildOfClass("Humanoid")
            local npcRoot = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart
            if humanoid and humanoid.Health > 0 and npcRoot then
                checkedNPCs[npc] = true
                local distance = (rootPart.Position - npcRoot.Position).Magnitude
                if distance <= CHAMS_RANGE then
                    if chamsEnabled then
                        createChams(npc)
                        if distance < closestDistance then
                            closestDistance = distance
                            closestNPC = npc
                        end
                    end
                else removeChams(npc) end
            else removeChams(npc) end
        end
    end
    for npc, highlight in pairs(chamObjects) do
        if not checkedNPCs[npc] or not npc.Parent then removeChams(npc)
        elseif npc == closestNPC then highlight.FillColor = Color3.fromRGB(102, 209, 90)
        else highlight.FillColor = Color3.fromRGB(167, 29, 226) end
    end
    if not chamsEnabled then
        for npc, _ in pairs(chamObjects) do removeChams(npc) end
    end
end

local function chamsLoop()
    RunService.Heartbeat:Connect(function() updateChams() end)
end

-- ==================== SWORD DAMAGE ESP FUNCTIONS ====================
local function createSwordESP(targetPlayer)
    if swordESPObjects[targetPlayer] then return end
    local character = targetPlayer.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    local damageValue = nil
    for _, tool in pairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            local damage = tool:FindFirstChild("Damage")
            if damage and damage:IsA("NumberValue") then
                damageValue = damage.Value
                break
            end
        end
    end
    if not damageValue then return end
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "SwordDMGESP"
    billboard.Adornee = rootPart
    billboard.Size = UDim2.new(0, 120, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = rootPart
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = abbreviateNumber(damageValue) .. " DMG"
    textLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    textLabel.TextStrokeTransparency = 0.5
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.GothamBold
    textLabel.Parent = billboard
    swordESPObjects[targetPlayer] = billboard
end

local function removeSwordESP(targetPlayer)
    if swordESPObjects[targetPlayer] then swordESPObjects[targetPlayer]:Destroy() swordESPObjects[targetPlayer] = nil end
end

local function updateSwordESP()
    if not swordDMGEnabled then
        for plr, billboard in pairs(swordESPObjects) do removeSwordESP(plr) end
        return
    end
    local checkedPlayers = {}
    for _, targetPlayer in pairs(Players:GetPlayers()) do
        if targetPlayer ~= player then
            checkedPlayers[targetPlayer] = true
            local character = targetPlayer.Character
            if character and character:FindFirstChild("HumanoidRootPart") then
                local hasDamageTool = false
                local damageValue = nil
                for _, tool in pairs(character:GetChildren()) do
                    if tool:IsA("Tool") then
                        local damage = tool:FindFirstChild("Damage")
                        if damage and damage:IsA("NumberValue") then
                            hasDamageTool = true
                            damageValue = damage.Value
                            break
                        end
                    end
                end
                if hasDamageTool and damageValue then
                    if swordESPObjects[targetPlayer] and swordESPObjects[targetPlayer].Parent then
                        local textLabel = swordESPObjects[targetPlayer]:FindFirstChildOfClass("TextLabel")
                        if textLabel then textLabel.Text = abbreviateNumber(damageValue) .. " DMG" end
                    else createSwordESP(targetPlayer) end
                else removeSwordESP(targetPlayer) end
            else removeSwordESP(targetPlayer) end
        end
    end
    for plr, _ in pairs(swordESPObjects) do
        if not checkedPlayers[plr] or not plr.Parent then removeSwordESP(plr) end
    end
end

local function swordESPLoop()
    RunService.Heartbeat:Connect(function() updateSwordESP() end)
end

Players.PlayerAdded:Connect(function(targetPlayer)
    targetPlayer.CharacterAdded:Connect(function()
        if swordESPObjects[targetPlayer] then removeSwordESP(targetPlayer) end
    end)
end)

-- ==================== LOOTING3 FUNCTIONS ====================
local function hasLooting3Enchants(sword)
    local enchant1 = sword:GetAttribute("Enchant1")
    local enchant2 = sword:GetAttribute("Enchant2")
    local enchant3 = sword:GetAttribute("Enchant3")
    return enchant1 == 8 and enchant2 == 8 and enchant3 == 8
end

local function createLooting3Part(sword)
    if looting3Parts[sword] then return end
    local mainPart = sword:FindFirstChild("Main")
    if not mainPart then return end
    local cylinder = Instance.new("Part")
    cylinder.Name = "Looting3Marker_" .. sword.Name
    cylinder.Shape = Enum.PartType.Cylinder
    cylinder.Size = Vector3.new(2048, 1.5, 1.5)
    cylinder.Material = Enum.Material.Neon
    cylinder.Color = Color3.fromRGB(117, 0, 0)
    cylinder.Transparency = 0.4
    cylinder.CanCollide = false
    cylinder.CanQuery = false
    cylinder.CanTouch = false
    cylinder.Anchored = true
    cylinder.Rotation = Vector3.new(0, 0, 90)
    cylinder.Parent = workspace
    looting3Parts[sword] = cylinder
    if not trackedSwords[sword] then
        trackedSwords[sword] = true
        playNotificationSound()
        print("Looting3 Sword Found: " .. sword.Name)
    end
    sword.AncestryChanged:Connect(function()
        if not sword:IsDescendantOf(workspace) then
            if looting3Parts[sword] then looting3Parts[sword]:Destroy() looting3Parts[sword] = nil end
            trackedSwords[sword] = nil
        end
    end)
end

local function removeLooting3Part(sword)
    if looting3Parts[sword] then looting3Parts[sword]:Destroy() looting3Parts[sword] = nil end
end

local function updateLooting3Parts()
    if not looting3Enabled then
        for sword, part in pairs(looting3Parts) do part:Destroy() end
        looting3Parts = {}
        trackedSwords = {}
        return
    end
    local swordsFolder = workspace:FindFirstChild("Swords")
    if not swordsFolder then return end
    local checkedSwords = {}
    for _, sword in pairs(swordsFolder:GetChildren()) do
        if sword:IsA("Model") then
            checkedSwords[sword] = true
            if hasLooting3Enchants(sword) then
                local mainPart = sword:FindFirstChild("Main")
                if mainPart then
                    if not looting3Parts[sword] then createLooting3Part(sword) end
                    if looting3Parts[sword] then
                        looting3Parts[sword].CFrame = mainPart.CFrame * CFrame.Angles(0, 0, math.rad(90))
                    end
                end
            else removeLooting3Part(sword) end
        end
    end
    for sword, part in pairs(looting3Parts) do
        if not checkedSwords[sword] or not sword.Parent then
            removeLooting3Part(sword)
            trackedSwords[sword] = nil
        end
    end
end

local function looting3Loop()
    RunService.Heartbeat:Connect(function() updateLooting3Parts() end)
end

-- ==================== LOW HEALTH AUTO TELEPORT ====================
local function setupHealthMonitor(character)
    local humanoid = character:WaitForChild("Humanoid")
    wasAboveThreshold = true
    humanoid.HealthChanged:Connect(function(health)
        local healthPercent = health / humanoid.MaxHealth
        local playerNearby = isPlayerNearby()
        local threshold = playerNearby and LOW_HEALTH_THRESHOLD_WITH_PLAYERS or LOW_HEALTH_THRESHOLD_NO_PLAYERS
        if healthPercent <= threshold and wasAboveThreshold then
            wasAboveThreshold = false
            local success, err = pcall(function()
                local args = {"Teleport Area", 3}
                ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction"):InvokeServer(unpack(args))
            end)
            if success then
                local thresholdText = playerNearby and "65% (player nearby)" or "30% (no players)"
                print("Low Health Teleport: Activated at " .. math.floor(healthPercent * 100) .. "% health (" .. thresholdText .. ")")
            else warn("Low Health Teleport: Failed - " .. tostring(err)) end
        elseif healthPercent > threshold then wasAboveThreshold = true end
    end)
end

